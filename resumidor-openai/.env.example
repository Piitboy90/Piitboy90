# ============================================
# VARIABLES DE ENTORNO - EJEMPLO
# ============================================
# 
# Copia este archivo a .env.local y completa
# los valores reales. NUNCA subas .env a GitHub.
#

# ============================================
# OPENAI API
# ============================================
# Tu API key de OpenAI
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# URL de tu proyecto Supabase
# Obtener en: Settings → General → Project URL
SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública de Supabase (anon)
# Obtener en: Settings → API → anon public
SUPABASE_ANON_KEY=sb_publishable_...

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# Puerto local para desarrollo
VITE_PORT=5173

# ============================================
# EDGE FUNCTION CONFIGURATION
# ============================================
# Nombre de la Edge Function
EDGE_FUNCTION_NAME=resumidor-openai

# URL completa de la Edge Function
EDGE_FUNCTION_URL=https://tu-proyecto.supabase.co/functions/v1/resumidor-openai

# ============================================
# DESARROLLO
# ============================================
# Modo debug (true/false)
DEBUG=false
